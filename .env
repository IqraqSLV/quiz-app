# Supabase Configuration
# These values will be provided by Codex after setting up the Supabase backend
# DO NOT commit this file to Git (it should be in .gitignore)

# Replace these placeholder values with actual credentials from Supabase dashboard
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here

# Instructions:
# 1. Wait for Codex to complete backend setup
# 2. Codex will provide the actual URL and Anon Key
# 3. Replace the placeholder values above
# 4. Restart the development server: npm start

# HR Helpdesk Backend
# P3-11: Override to point at a deployed backend (default: http://localhost:8000)
REACT_APP_API_BASE=http://localhost:8000
